5:["$","p",null,{"children":["This Privacy Policy explains how ",["$","strong",null,{"children":"Eman Clinic"}]," (\"Eman Clinic\", \"we\", \"our\", or \"us\") collects, uses, discloses, and safeguards personal, health, and usage information when you access our digital clinic platform, related mobile or web interfaces, and connected services (collectively, the \"Services\"). We are committed to protecting confidentiality, integrity, and lawful processing of healthcare data."]}]
6:["$","section","scope",{"id":"scope","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"2. Scope & Regulatory Alignment"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","p",null,{"children":"This Policy applies to all users including patients, clinicians, administrative staff, and third-party integrators. We apply principles consistent with internationally recognized health data standards (e.g. confidentiality, minimum necessary use, purpose limitation, security-by-design). Where local law imposes stricter requirements, those obligations prevail."}]}]]}]
7:["$","section","data-we-collect",{"id":"data-we-collect","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"3. Information We Collect"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","ul",null,{"className":"list-disc pl-5 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Identity Data:"}]," name, date of birth, gender, identifiers issued by us or your organization."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Contact Data:"}]," email, phone, address, emergency contact (if provided)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Clinical / Patient Data:"}]," visit notes, lab orders/results, medications, allergies, services rendered, billing codes."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Account & Authentication:"}]," role, permissions, audit trail entries, session tokens."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Financial Data:"}]," limited payment metadata (we do not store full card numbers if processed by a PCI compliant processor)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Usage & Technical:"}]," device type, browser, IP address, timestamps, feature interaction, error logs (pseudonymized when feasible)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Optional Feedback:"}]," survey responses, support tickets, feature requests."]}]]}]}]]}]
8:["$","section","how-we-use",{"id":"how-we-use","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"4. How We Use Information"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","ul",null,{"className":"list-disc pl-5 space-y-2","children":[["$","li",null,{"children":"Deliver core clinic workflows (scheduling, charting, medication / inventory management, reporting)."}],["$","li",null,{"children":"Authenticate users; enforce role-based access control (RBAC) and auditability."}],["$","li",null,{"children":"Generate internal analytics to improve reliability, quality of care tooling, and user experience (aggregated / de‑identified whenever possible)."}],["$","li",null,{"children":"Provide patient safety alerts (drug interactions, abnormal results) where supported."}],["$","li",null,{"children":"Detect, investigate, and prevent security incidents or misuse."}],["$","li",null,{"children":"Comply with legal, accreditation, or regulatory obligations and respond to lawful requests."}],["$","li",null,{"children":"Communicate service notices, updates, and support responses."}]]}]}]]}]
9:["$","section","lawful-bases",{"id":"lawful-bases","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"5. Legal / Lawful Bases"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","p",null,{"children":"We process data under one or more of: (a) performance of a healthcare or service provision contract; (b) legitimate interests in operating and securing the platform (balanced against user rights); (c) explicit consent where required (e.g. optional marketing); (d) compliance with legal obligations; (e) protection of vital interests in emergent scenarios."}]}]]}]
a:["$","section","sharing",{"id":"sharing","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"6. Disclosure & Sharing"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","ul",null,{"className":"list-disc pl-5 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Authorized Clinical Personnel:"}]," Access controlled by role and least-privilege."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Service Providers:"}]," Hosting, email delivery, analytics, secure payment processors—bound by confidentiality and data processing agreements."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Regulators / Legal:"}]," If required by applicable law, court order, or to protect rights, safety, or system integrity."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Research & Analytics:"}]," Only aggregated or de‑identified outputs unless explicit consent or lawful basis permits otherwise."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Business Continuity:"}]," In a merger or acquisition, subject to equivalent safeguards and notice."]}]]}]}]]}]
b:["$","section","transfers",{"id":"transfers","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"7. International / Cross-Border Handling"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","p",null,{"children":"Data may be processed in jurisdictions where our infrastructure or vetted subcontractors operate. We implement logical isolation, encryption in transit & at rest, strict access logging, and contractual clauses where required to maintain comparable protection levels."}]}]]}]
c:["$","section","retention",{"id":"retention","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"8. Retention"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","p",null,{"children":"We retain personal and clinical data only for the duration necessary to deliver Services, meet clinical recordkeeping obligations, resolve disputes, and enforce agreements. When no longer required, we securely delete or irreversibly de‑identify data using industry-standard procedures."}]}]]}]
d:["$","section","security",{"id":"security","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"9. Security Controls"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","ul",null,{"className":"list-disc pl-5 space-y-2","children":[["$","li",null,{"children":"Encryption (TLS in transit, encrypted storage for sensitive records)."}],["$","li",null,{"children":"Role-based access, multi-factor authentication support, and session timeouts."}],["$","li",null,{"children":"Audit logging of privileged actions and data access pathways."}],["$","li",null,{"children":"Segregated environments (production vs. test) and principle of least privilege."}],["$","li",null,{"children":"Routine vulnerability scanning and secure development lifecycle practices."}]]}]}]]}]
e:["$","section","rights",{"id":"rights","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"10. User & Patient Rights"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","ul",null,{"className":"list-disc pl-5 space-y-2","children":[["$","li",null,{"children":"Access / obtain a copy of your data within reasonable system capabilities."}],["$","li",null,{"children":"Request correction of inaccurate information."}],["$","li",null,{"children":"Request deletion where retention is not legally or clinically mandated."}],["$","li",null,{"children":"Object or restrict certain processing (e.g. analytics) where legally permitted."}],["$","li",null,{"children":"Portability of certain structured data (on request and feasibility)."}],["$","li",null,{"children":"Withdraw consent for optional communications."}]]}]}]]}]
f:["$","section","children",{"id":"children","className":"scroll-mt-28","children":[["$","h2",null,{"className":"text-xl md:text-2xl font-semibold mb-4 text-text-primary","children":"11. Children & Vulnerable Persons"}],["$","div",null,{"className":"prose prose-sm md:prose-base max-w-none leading-relaxed prose-headings:text-text-primary prose-p:text-text-secondary prose-li:text-text-secondary dark:prose-invert","children":["$","p",null,{"children":"Accounts for minors or vulnerable patients are created and managed only by authorized clinical or guardian stakeholders consistent with applicable law. We do not intentionally market Services directly to minors."}]}]]}]
